{
  "name": "specsync-agent",
  "version": "1.0.0",
  "description": "AI-powered architectural guardrail for GitHub repositories",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && ncc build dist/index.js -o action-dist",
    "build:ts": "tsc",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "prepublish": "npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@anthropic-ai/sdk": "^0.36.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "typescript": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2"
  },
  "keywords": [
